@model IEnumerable<EquipmentBorrowingSystem.Models.Count_Borrowing_Times>
@{
    ViewBag.Title = "統計設備借用次數";
    Layout = "~/Views/Shared/_Layout_Manager.cshtml";

    var totalBorrows = Model.Sum(m => int.TryParse(m.ECount_Borrowing_Times, out var v) ? v : 0);
    var topItem = Model.FirstOrDefault();
    var totalTypes = Model.Count();
    var rank = 0;
}

<div class="page-header">
    <h4><i class="bi bi-bar-chart-line me-2" style="color:#5b9bd5;"></i>設備借用統計分析</h4>
    <p class="page-subtitle">綜合統計所有設備的借用頻率，協助庫存與採購決策</p>
</div>

@* ===== 日期區間篩選 ===== *@
<div class="content-card mb-4">
    <div class="p-3">
        <form action="@Url.Action("Count_Borrowing_Times_selectdate", "Count_Borrowing_Times")" method="post" onsubmit="return validateDates();" class="d-flex flex-wrap align-items-end gap-3">
            <div>
                <label class="form-label fw-semibold small mb-1"><i class="bi bi-calendar-event me-1"></i>起始日期</label>
                <input type="date" id="Date1" name="Date1" class="form-control form-control-sm" required autocomplete="off" />
            </div>
            <div class="d-flex align-items-center pt-4"><span class="text-muted">～</span></div>
            <div>
                <label class="form-label fw-semibold small mb-1"><i class="bi bi-calendar-event me-1"></i>結束日期</label>
                <input type="date" id="Date2" name="Date2" class="form-control form-control-sm" required autocomplete="off" />
            </div>
            <div class="pt-4">
                <button type="submit" class="btn btn-sm text-white px-4" style="background:var(--accent-color);">
                    <i class="bi bi-search me-1"></i>篩選查詢
                </button>
            </div>
            <div class="pt-4">
                <a href="@Url.Action("Count_Borrowing_Times", "Count_Borrowing_Times")" class="btn btn-sm btn-outline-secondary px-3">
                    <i class="bi bi-arrow-counterclockwise me-1"></i>重置（全部）
                </a>
            </div>
        </form>
    </div>
</div>

@* ===== KPI 卡片 ===== *@
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="stat-card stat-primary">
            <div class="stat-icon"><i class="bi bi-bar-chart-fill"></i></div>
            <div>
                <div class="stat-number">@totalBorrows</div>
                <div class="stat-label">總借用次數</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card stat-success">
            <div class="stat-icon"><i class="bi bi-box-seam"></i></div>
            <div>
                <div class="stat-number">@totalTypes</div>
                <div class="stat-label">設備種類數</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card stat-warning">
            <div class="stat-icon"><i class="bi bi-trophy-fill"></i></div>
            <div>
                <div class="stat-number" style="font-size:1rem;">@(topItem != null ? topItem.EName : "-")</div>
                <div class="stat-label">最熱門設備</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card stat-info">
            <div class="stat-icon"><i class="bi bi-graph-up-arrow"></i></div>
            <div>
                <div class="stat-number">@(totalTypes > 0 ? (totalBorrows / totalTypes).ToString() : "0")</div>
                <div class="stat-label">平均借用次數</div>
            </div>
        </div>
    </div>
</div>

@* ===== 圖表區 ===== *@
<div class="row g-4 mb-4">
    <div class="col-lg-7">
        <div class="content-card h-100">
            <div class="content-card-header d-flex justify-content-between align-items-center">
                <h5><i class="bi bi-bar-chart"></i> 借用次數排行</h5>
                <small class="text-muted">至今日為止</small>
            </div>
            <div class="p-3">
                @if (Model.Any())
                {
                    <canvas id="barChart" style="max-height:400px;"></canvas>
                }
                else
                {
                    <div class="text-center text-muted py-5"><i class="bi bi-inbox fs-1 d-block mb-2" style="opacity:.3;"></i>尚無統計資料</div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="content-card h-100">
            <div class="content-card-header d-flex justify-content-between align-items-center">
                <h5><i class="bi bi-pie-chart"></i> 借用比例分布</h5>
                <small class="text-muted">佔比分析</small>
            </div>
            <div class="p-3">
                @if (Model.Any())
                {
                    <canvas id="pieChart" style="max-height:350px;"></canvas>
                }
                else
                {
                    <div class="text-center text-muted py-5"><i class="bi bi-inbox fs-1 d-block mb-2" style="opacity:.3;"></i>尚無統計資料</div>
                }
            </div>
        </div>
    </div>
</div>

@* ===== 詳細排行表格 ===== *@
<div class="content-card mb-4">
    <div class="content-card-header">
        <h5><i class="bi bi-table"></i> 設備借用次數排行榜</h5>
    </div>
    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover mb-0" style="font-size:.85rem;">
                <thead style="background:#f0f4f8;">
                    <tr>
                        <th class="text-center" style="width:7%;">排名</th>
                        <th style="width:30%;">設備名稱</th>
                        <th style="width:25%;">設備型號</th>
                        <th style="width:15%;" class="text-center">借用次數</th>
                        <th style="width:23%;">佔比</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        rank++;
                        var count = int.TryParse(item.ECount_Borrowing_Times, out var c) ? c : 0;
                        var pct = totalBorrows > 0 ? (count * 100.0 / totalBorrows) : 0;
                        var medalClass = rank == 1 ? "text-warning" : rank == 2 ? "text-secondary" : rank == 3 ? "text-danger" : "text-muted";
                        var medalIcon = rank <= 3 ? "bi-trophy-fill" : "bi-dot";
                        <tr>
                            <td class="text-center">
                                <span class="@medalClass"><i class="bi @medalIcon me-1"></i></span>
                                <strong>@rank</strong>
                            </td>
                            <td class="fw-semibold">@item.EName</td>
                            <td>@item.Emodel</td>
                            <td class="text-center">
                                <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-1" style="font-size:.82rem;">@item.ECount_Borrowing_Times</span>
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="progress flex-grow-1" style="height:8px;">
                                        <div class="progress-bar" role="progressbar" style="width:@pct.ToString("F1")%;background:var(--accent-color);" aria-valuenow="@pct" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                    <small class="text-muted" style="min-width:40px;">@pct.ToString("F1")%</small>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center text-muted py-5"><i class="bi bi-inbox fs-1 d-block mb-2" style="opacity:.3;"></i>尚無借用統計資料</div>
    }
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script>
    function validateDates() {
        var d1 = document.getElementById('Date1').value;
        var d2 = document.getElementById('Date2').value;
        if (d1 > d2) { alert('結束日期不能早於起始日期'); return false; }
        return true;
    }

    @if (Model.Any())
    {
        var labels = Model.Select(m => m.EName + " — " + m.Emodel).ToList();
        var values = Model.Select(m => m.ECount_Borrowing_Times).ToList();
        <text>
    var labels = @Html.Raw(Json.Serialize(labels));
    var rawData = @Html.Raw(Json.Serialize(values));
    var numData = rawData.map(Number);

    var palette = [
        '#5b9bd5','#3a7bc8','#2e86de','#54a0ff','#48dbfb',
        '#1dd1a1','#10ac84','#feca57','#ff9f43','#ee5a24',
        '#6c5ce7','#a29bfe','#fd79a8','#e17055','#00cec9'
    ];

    // Bar Chart
    new Chart(document.getElementById('barChart'), {
        type: 'bar',
        data: {
            labels: labels,
            datasets: [{
                label: '借用次數',
                data: numData,
                backgroundColor: palette.slice(0, labels.length).map(function(c) { return c + 'CC'; }),
                borderColor: palette.slice(0, labels.length),
                borderWidth: 1,
                borderRadius: 6
            }]
        },
        options: {
            indexAxis: 'y',
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false },
                tooltip: {
                    callbacks: {
                        label: function(ctx) { return ' ' + ctx.parsed.x + ' 次'; }
                    }
                }
            },
            scales: {
                x: {
                    beginAtZero: true,
                    ticks: { stepSize: 1, font: { size: 12 } },
                    title: { display: true, text: '借用次數', color: '#495057', font: { size: 13, weight: 'bold' } },
                    grid: { color: 'rgba(0,0,0,0.05)' }
                },
                y: {
                    title: { display: false },
                    grid: { display: false },
                    ticks: { font: { size: 11 } }
                }
            }
        }
    });

    // Pie Chart
    new Chart(document.getElementById('pieChart'), {
        type: 'doughnut',
        data: {
            labels: labels,
            datasets: [{
                data: numData,
                backgroundColor: palette.slice(0, labels.length),
                borderWidth: 2,
                borderColor: '#fff',
                hoverOffset: 8
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    position: 'bottom',
                    labels: { padding: 12, usePointStyle: true, pointStyle: 'circle', font: { size: 11 } }
                },
                tooltip: {
                    callbacks: {
                        label: function(ctx) {
                            var total = ctx.dataset.data.reduce(function(a,b) { return a+b; }, 0);
                            var pct = total > 0 ? (ctx.parsed / total * 100).toFixed(1) : 0;
                            return ' ' + ctx.label + '：' + ctx.parsed + ' 次（' + pct + '%）';
                        }
                    }
                }
            }
        }
    });
        </text>
    }
</script>
}
