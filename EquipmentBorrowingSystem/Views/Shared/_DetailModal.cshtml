@* ==================== 申請詳細資訊 Modal（共用） ==================== *@
<div class="modal fade" id="detailModal" tabindex="-1" aria-labelledby="detailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content" style="border-radius:12px; overflow:hidden;">
            <div class="modal-header" style="background:linear-gradient(135deg,#5b9bd5 0%,#3a7bc8 100%); color:#fff; border:none; padding:16px 24px;">
                <h6 class="modal-title fw-bold" id="detailModalLabel">
                    <i class="bi bi-clipboard-data me-2"></i>申請詳細資訊
                </h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <!-- Loading -->
                <div id="modalLoading" class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div>
                    <div class="mt-2 text-muted small">載入中...</div>
                </div>
                <!-- Content -->
                <div id="modalContent" style="display:none;">
                    <!-- 基本資訊 -->
                    <div class="px-4 pt-3 pb-2" style="background:#f8f9fb;">
                        <div class="row g-2">
                            <div class="col-sm-6">
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <span class="d-inline-flex align-items-center justify-content-center" style="width:32px;height:32px;border-radius:50%;background:rgba(91,155,213,0.15);color:#5b9bd5;">
                                        <i class="bi bi-person-fill"></i>
                                    </span>
                                    <div>
                                        <div class="text-muted" style="font-size:.7rem;">借用人</div>
                                        <div class="fw-semibold" id="modalName">-</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <span class="d-inline-flex align-items-center justify-content-center" style="width:32px;height:32px;border-radius:50%;background:rgba(91,155,213,0.15);color:#5b9bd5;">
                                        <i class="bi bi-chat-left-text-fill"></i>
                                    </span>
                                    <div>
                                        <div class="text-muted" style="font-size:.7rem;">用途說明</div>
                                        <div class="fw-semibold" id="modalIllustrate">-</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row g-2">
                            <div class="col-sm-6">
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <span class="d-inline-flex align-items-center justify-content-center" style="width:32px;height:32px;border-radius:50%;background:rgba(39,174,96,0.12);color:#1a7a33;">
                                        <i class="bi bi-box-arrow-up-right"></i>
                                    </span>
                                    <div>
                                        <div class="text-muted" style="font-size:.7rem;">借用時間</div>
                                        <div class="fw-semibold" style="color:#1a7a33;" id="modalBorrowTime">-</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <span class="d-inline-flex align-items-center justify-content-center" style="width:32px;height:32px;border-radius:50%;background:rgba(192,57,43,0.12);color:#c0392b;">
                                        <i class="bi bi-box-arrow-in-down-left"></i>
                                    </span>
                                    <div>
                                        <div class="text-muted" style="font-size:.7rem;">歸還時間</div>
                                        <div class="fw-semibold" style="color:#c0392b;" id="modalReturnTime">-</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row g-2 mb-1">
                            <div class="col-sm-6">
                                <small class="text-muted"><i class="bi bi-telephone me-1"></i><span id="modalMobile">-</span></small>
                            </div>
                            <div class="col-sm-6">
                                <small class="text-muted"><i class="bi bi-envelope me-1"></i><span id="modalEmail">-</span></small>
                            </div>
                        </div>
                        <!-- 管理者額外資訊（證件抵押、移交/接收人） -->
                        <div id="modalManagerInfo" class="row g-2 mt-1 pt-2" style="border-top:1px solid #e9ecef; display:none;">
                            <div class="col-sm-4">
                                <small class="text-muted d-block" style="font-size:.7rem;">證件抵押</small>
                                <small class="fw-semibold" id="modalCredentials">-</small>
                            </div>
                            <div class="col-sm-4">
                                <small class="text-muted d-block" style="font-size:.7rem;">移交人(借出)</small>
                                <small class="fw-semibold" id="modalHandover">-</small>
                            </div>
                            <div class="col-sm-4">
                                <small class="text-muted d-block" style="font-size:.7rem;">接收人(歸還)</small>
                                <small class="fw-semibold" id="modalReceive">-</small>
                            </div>
                        </div>
                    </div>

                    <!-- 設備清單 -->
                    <div class="px-4 pt-3 pb-2">
                        <h6 class="fw-bold mb-2" style="font-size:.85rem;">
                            <i class="bi bi-box-seam me-1 text-primary"></i>借用設備
                            <small class="text-muted fw-normal ms-1" style="font-size:.72rem;">（點擊 <i class="bi bi-image"></i> 可查看設備圖片）</small>
                        </h6>
                        <div class="table-responsive">
                            <table class="table table-sm table-hover mb-0" style="font-size:.82rem;">
                                <thead style="background:#f0f4f8;">
                                    <tr><th style="width:5%"></th><th>設備名稱</th><th>型號</th><th>編號</th><th>來源</th></tr>
                                </thead>
                                <tbody id="modalEquipmentBody"></tbody>
                            </table>
                        </div>
                        <div id="modalNoEquipment" class="text-center text-muted py-2 small" style="display:none;">無借用設備</div>
                    </div>

                    <!-- 消耗品清單 -->
                    <div id="modalConsumablesSection" class="px-4 pt-2 pb-3">
                        <h6 class="fw-bold mb-2" style="font-size:.85rem;">
                            <i class="bi bi-droplet me-1 text-warning"></i>消耗品
                        </h6>
                        <div class="table-responsive">
                            <table class="table table-sm table-hover mb-0" style="font-size:.82rem;">
                                <thead style="background:#fef9f0;">
                                    <tr><th style="width:5%"></th><th>名稱</th><th>型號</th><th>數量</th><th>來源</th></tr>
                                </thead>
                                <tbody id="modalConsumablesBody"></tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <!-- Error -->
                <div id="modalError" class="text-center py-5 text-danger" style="display:none;">
                    <i class="bi bi-exclamation-triangle fs-3 d-block mb-2"></i>載入失敗，請重試
                </div>
            </div>
            <div class="modal-footer border-0 px-4 pb-3 pt-0">
                <button type="button" class="btn btn-sm btn-outline-secondary px-4" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg me-1"></i>關閉
                </button>
            </div>
        </div>
    </div>
</div>

@* ==================== 設備圖片預覽 Modal ==================== *@
<div class="modal fade" id="eqImageModal" tabindex="-1" aria-hidden="true" style="z-index:1070;">
    <div class="modal-dialog modal-dialog-centered" style="max-width:480px;">
        <div class="modal-content" style="border-radius:12px; overflow:hidden;">
            <div class="modal-header py-2" style="background:#f0f4f8; border-bottom:1px solid #e9ecef;">
                <h6 class="modal-title fw-bold" style="font-size:.85rem;" id="eqImageTitle">設備圖片</h6>
                <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center p-3">
                <img id="eqImagePreview" src="" alt="設備圖片" style="max-width:100%; max-height:400px; border-radius:8px; object-fit:contain;" />
                <div id="eqImageNone" class="py-4 text-muted" style="display:none;">
                    <i class="bi bi-image fs-1 d-block mb-2" style="opacity:.3;"></i>
                    <small>此設備尚未上傳圖片</small>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="modal-backdrop fade" id="eqImageBackdrop" style="display:none; z-index:1065;"></div>

<script>
    function showDetailModal(fOrderGuid, apiUrl) {
        var modal = new bootstrap.Modal(document.getElementById('detailModal'));
        var loading = document.getElementById('modalLoading');
        var content = document.getElementById('modalContent');
        var error = document.getElementById('modalError');

        loading.style.display = 'block';
        content.style.display = 'none';
        error.style.display = 'none';
        modal.show();

        fetch(apiUrl + '?fOrderGuid=' + encodeURIComponent(fOrderGuid))
            .then(function (res) {
                if (!res.ok) throw new Error('Not found');
                return res.json();
            })
            .then(function (data) {
                document.getElementById('modalName').textContent = data.name || '-';
                document.getElementById('modalBorrowTime').textContent = data.borrowTime || '-';
                document.getElementById('modalReturnTime').textContent = data.returnTime || '-';
                document.getElementById('modalIllustrate').textContent = data.illustrate || '-';
                document.getElementById('modalMobile').textContent = data.mobile || '無';
                document.getElementById('modalEmail').textContent = data.email || '無';

                // 管理者額外資訊
                var mgrInfo = document.getElementById('modalManagerInfo');
                if (data.credentialsMortgage || data.handoverPerson || data.receivePerson) {
                    mgrInfo.style.display = 'flex';
                    document.getElementById('modalCredentials').textContent = data.credentialsMortgage || '-';
                    document.getElementById('modalHandover').textContent = data.handoverPerson || '-';
                    document.getElementById('modalReceive').textContent = (data.receivePerson && data.receivePerson.trim()) ? data.receivePerson : '-';
                } else {
                    mgrInfo.style.display = 'none';
                }

                // 設備表格
                var eqBody = document.getElementById('modalEquipmentBody');
                var noEq = document.getElementById('modalNoEquipment');
                eqBody.innerHTML = '';
                if (data.equipment && data.equipment.length > 0) {
                    noEq.style.display = 'none';
                    data.equipment.forEach(function (eq) {
                        var hasImg = eq.eImage && eq.eImage.trim() && eq.eImage.trim() !== ' ';
                        var imgBtn = hasImg
                            ? '<button class="btn btn-sm p-0 border-0" onclick="showEqImage(\'' + _escAttr(eq.eImage) + '\', \'' + _escAttr(eq.eName) + ' ' + _escAttr(eq.emodel) + '\')" title="查看圖片"><i class="bi bi-image text-primary" style="font-size:1rem;"></i></button>'
                            : '<i class="bi bi-image text-muted" style="font-size:.9rem; opacity:.3;" title="無圖片"></i>';
                        var tr = document.createElement('tr');
                        tr.innerHTML = '<td class="text-center">' + imgBtn + '</td><td>' + _esc(eq.eName) + '</td><td>' + _esc(eq.emodel) + '</td><td><span class="badge bg-light text-dark border">' + _esc(eq.eId) + '</span></td><td><small class="text-muted">' + _esc(eq.eSource) + '</small></td>';
                        eqBody.appendChild(tr);
                    });
                } else {
                    noEq.style.display = 'block';
                }

                // 消耗品表格
                var csBody = document.getElementById('modalConsumablesBody');
                var csSection = document.getElementById('modalConsumablesSection');
                csBody.innerHTML = '';
                if (data.consumables && data.consumables.length > 0) {
                    csSection.style.display = 'block';
                    data.consumables.forEach(function (cs) {
                        var hasImg = cs.eImage && cs.eImage.trim() && cs.eImage.trim() !== ' ';
                        var imgBtn = hasImg
                            ? '<button class="btn btn-sm p-0 border-0" onclick="showEqImage(\'' + _escAttr(cs.eImage) + '\', \'' + _escAttr(cs.eName) + ' ' + _escAttr(cs.emodel) + '\')" title="查看圖片"><i class="bi bi-image text-primary" style="font-size:1rem;"></i></button>'
                            : '<i class="bi bi-image text-muted" style="font-size:.9rem; opacity:.3;" title="無圖片"></i>';
                        var tr = document.createElement('tr');
                        tr.innerHTML = '<td class="text-center">' + imgBtn + '</td><td>' + _esc(cs.eName) + '</td><td>' + _esc(cs.emodel) + '</td><td><span class="badge bg-warning text-dark">x' + _esc(cs.quantity) + '</span></td><td><small class="text-muted">' + _esc(cs.eSource) + '</small></td>';
                        csBody.appendChild(tr);
                    });
                } else {
                    csSection.style.display = 'none';
                }

                loading.style.display = 'none';
                content.style.display = 'block';
            })
            .catch(function () {
                loading.style.display = 'none';
                error.style.display = 'block';
            });
    }

    // 顯示設備圖片預覽
    function showEqImage(imageName, title) {
        var imgEl = document.getElementById('eqImagePreview');
        var noneEl = document.getElementById('eqImageNone');
        document.getElementById('eqImageTitle').textContent = title || '設備圖片';

        if (imageName && imageName.trim() && imageName.trim() !== ' ') {
            imgEl.src = '/Image/' + encodeURIComponent(imageName.trim());
            imgEl.style.display = 'block';
            noneEl.style.display = 'none';
        } else {
            imgEl.style.display = 'none';
            noneEl.style.display = 'block';
        }

        var imgModal = new bootstrap.Modal(document.getElementById('eqImageModal'));
        imgModal.show();
    }

    function _esc(str) {
        if (!str) return '';
        var d = document.createElement('div');
        d.appendChild(document.createTextNode(str));
        return d.innerHTML;
    }

    function _escAttr(str) {
        if (!str) return '';
        return str.replace(/\\/g, '\\\\').replace(/'/g, "\\'").replace(/"/g, '&quot;');
    }
</script>
