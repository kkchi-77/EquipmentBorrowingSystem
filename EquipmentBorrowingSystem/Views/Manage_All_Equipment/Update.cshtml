@model EquipmentBorrowingSystem.ViewModel.EquipmentViewModel
@{
    ViewData["Title"] = "修改設備";
    Layout = "~/Views/Shared/_Layout_Manager.cshtml";
    var eq = Model.Equipment.FirstOrDefault();
}

<div class="page-header">
    <h4><i class="bi bi-pencil-square me-2" style="color:#5b9bd5;"></i>修改設備資料</h4>
    <p class="page-subtitle">@eq?.EName — @eq?.Emodel (@Model.ESource)</p>
</div>

<div class="content-card mb-3">
    <div class="content-card-header">
        <h5><i class="bi bi-box-seam"></i> 基本資料</h5>
    </div>
    <div class="p-3">
        @if (eq != null)
        {
            <form action="@Url.Action("Update_Edit", "Manage_All_Equipment")" method="post" enctype="multipart/form-data">
                <input type="hidden" name="EName_old" value="@eq.EName" />
                <input type="hidden" name="Emodel_old" value="@eq.Emodel" />
                <input type="hidden" name="ESource_old" value="@Model.ESource" />
                <input type="hidden" name="EImage_old" value="@eq.EImage" />

                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label fw-semibold small">設備名稱 <span class="text-danger">*</span></label>
                        <input type="text" name="EName" class="form-control form-control-sm" required autocomplete="off" value="@eq.EName" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold small">設備型號 <span class="text-danger">*</span></label>
                        <input type="text" name="Emodel" class="form-control form-control-sm" required autocomplete="off" value="@eq.Emodel" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-semibold small">設備總數量 <span class="text-danger">*</span></label>
                        <input type="number" id="eqQtyInput" name="EQuantity" class="form-control form-control-sm" required autocomplete="off" value="@eq.EQuantity" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-semibold small">數量單位 <span class="text-danger">*</span></label>
                        <input type="text" name="EQuantity_Unit" class="form-control form-control-sm" required autocomplete="off" value="@eq.EQuantity_Unit" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold small">設備來源 <span class="text-danger">*</span></label>
                        <select name="ESource" class="form-select form-select-sm" required>
                            @if (Model.ESource == "自購")
                            {
                                <option value="自購" selected>自購</option>
                                <option value="教育局">教育局</option>
                            }
                            else
                            {
                                <option value="自購">自購</option>
                                <option value="教育局" selected>教育局</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold small">是否為消耗品</label>
                        <div class="d-flex gap-3 mt-1">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="Is_Consumable" id="consumableNo" value="False" @(Model.Is_Consumable == "False" ? "checked" : "")>
                                <label class="form-check-label small" for="consumableNo">否</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="Is_Consumable" id="consumableYes" value="True" @(Model.Is_Consumable == "True" ? "checked" : "")>
                                <label class="form-check-label small" for="consumableYes">是</label>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold small">更換設備圖片</label>
                        <input type="file" name="FileInput" class="form-control form-control-sm" accept="image/*" />
                        @if (!string.IsNullOrWhiteSpace(eq.EImage) && eq.EImage.Trim() != "")
                        {
                            <small class="text-muted">目前：@eq.EImage</small>
                        }
                    </div>
                </div>

                @* ===== 設備編號列表（非消耗品才顯示）===== *@
                @if (Model.Is_Consumable == "False" && Model.Equipment_Details != null && Model.Equipment_Details.Any())
                {
                    <hr class="my-3" />
                    <h6 class="fw-bold mb-3"><i class="bi bi-list-ol me-1" style="color:#5b9bd5;"></i>設備編號及詳細資訊</h6>
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0" style="font-size:.82rem;">
                            <thead style="background:#f0f4f8;">
                                <tr>
                                    <th class="text-center" style="width:6%">#</th>
                                    <th style="width:22%">設備編號</th>
                                    <th style="width:20%">借用狀態</th>
                                    <th style="width:52%">設備存放位置</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{ var detailIdx = 0; }
                                @foreach (var d in Model.Equipment_Details)
                                {
                                    detailIdx++;
                                    <tr>
                                        <td class="text-center text-muted">@detailIdx</td>
                                        <td>
                                            <input type="text" name="EId[]" class="form-control form-control-sm" value="@d.EId" autocomplete="off" />
                                        </td>
                                        <td>
                                            <select name="IsBorrow[]" class="form-select form-select-sm">
                                                @{
                                                    var borrowOptions = new[] { ("False", "未借出"), ("True", "借用中"), ("Missing", "遺失") };
                                                }
                                                @foreach (var opt in borrowOptions)
                                                {
                                                    if (d.IsBorrow == opt.Item1)
                                                    {
                                                        <option value="@opt.Item1" selected>@opt.Item2</option>
                                                    }
                                                    else
                                                    {
                                                        <option value="@opt.Item1">@opt.Item2</option>
                                                    }
                                                }
                                            </select>
                                        </td>
                                        <td>
                                            <input type="text" name="ECurrent_Location_update[]" class="form-control form-control-sm" value="@d.ECurrent_Location" autocomplete="off" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                <hr class="my-3" />
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-check-circle me-1"></i>儲存修改
                    </button>
                    <a href="@Url.Action("Browse_All_equipment", "Manage_All_Equipment")" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-arrow-left me-1"></i>返回
                    </a>
                </div>
            </form>
        }
    </div>
</div>
