@model EquipmentBorrowingSystem.Models.Equipment
@{
    ViewData["Title"] = "新增設備";
    Layout = "~/Views/Shared/_Layout_Manager.cshtml";
}

<div class="page-header">
    <h4><i class="bi bi-plus-circle me-2" style="color:#5b9bd5;"></i>新增設備</h4>
    <p class="page-subtitle">新增一筆設備資料至系統</p>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-1"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="content-card mb-3">
    <div class="content-card-header">
        <h5><i class="bi bi-box-seam"></i> 設備基本資料</h5>
    </div>
    <div class="p-3">
        <form action="@Url.Action("Create", "Manage_All_Equipment")" method="post" enctype="multipart/form-data">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label fw-semibold small">設備名稱 <span class="text-danger">*</span></label>
                    <input type="text" name="EName" class="form-control form-control-sm" required autocomplete="off" placeholder="例如：VR頭盔 (含手把)" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold small">設備型號 <span class="text-danger">*</span></label>
                    <input type="text" name="Emodel" class="form-control form-control-sm" required autocomplete="off" placeholder="例如：Meta Quest 3" />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold small">數量單位 <span class="text-danger">*</span></label>
                    <input type="text" name="EQuantity_Unit" class="form-control form-control-sm" required autocomplete="off" placeholder="台、個、條..." />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold small">設備來源 <span class="text-danger">*</span></label>
                    <select id="eSourceSelect" name="ESource" class="form-select form-select-sm" required onchange="toggleESourceOther()">
                        <option value="">-- 請選擇 --</option>
                        <option value="自購">自購</option>
                        <option value="教育局">教育局</option>
                        <option value="__other__">其他（自訂）</option>
                    </select>
                    <input type="text" id="eSourceCustom" class="form-control form-control-sm mt-1" placeholder="請輸入來源" autocomplete="off" style="display:none;" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold small">是否為消耗品 <span class="text-danger">*</span></label>
                    <div class="d-flex gap-3 mt-1">
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="Is_Consumable" id="consumableNo" value="False" required onchange="toggleConsumable()">
                            <label class="form-check-label small" for="consumableNo">否（一般設備）</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="Is_Consumable" id="consumableYes" value="True" onchange="toggleConsumable()">
                            <label class="form-check-label small" for="consumableYes">是（消耗品）</label>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold small">設備存放位置 <span class="text-danger">*</span></label>
                    <input type="text" name="ECurrent_Location" class="form-control form-control-sm" required autocomplete="off" value="數位內容設計研究中心" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold small">設備圖片</label>
                    <input type="file" name="FileInput" class="form-control form-control-sm" accept="image/*" />
                </div>

                @* 一般設備：輸入數量後動態產生編號欄位 *@
                <div class="col-12" id="equipmentSection" style="display:none;">
                    <hr class="my-2" />
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label fw-semibold small">設備總數量 <span class="text-danger">*</span></label>
                            <input type="number" id="eqQtyInput" name="EQuantityYes" class="form-control form-control-sm" min="1" autocomplete="off" />
                        </div>
                        <div class="col-12" id="eidContainer"></div>
                    </div>
                </div>

                @* 消耗品：只輸入數量 *@
                <div class="col-md-3" id="consumableSection" style="display:none;">
                    <label class="form-label fw-semibold small">數量 <span class="text-danger">*</span></label>
                    <input type="number" name="EQuantityNo" class="form-control form-control-sm" min="1" autocomplete="off" />
                </div>
            </div>

            <hr class="my-3" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success px-4">
                    <i class="bi bi-check-circle me-1"></i>新增設備
                </button>
                <a href="@Url.Action("Browse_All_equipment", "Manage_All_Equipment")" class="btn btn-outline-secondary px-4">
                    <i class="bi bi-arrow-left me-1"></i>返回
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    function toggleESourceOther() {
        var sel = document.getElementById('eSourceSelect');
        var custom = document.getElementById('eSourceCustom');
        if (sel.value === '__other__') {
            custom.style.display = '';
            custom.required = true;
            custom.name = 'ESource';
            sel.removeAttribute('name');
        } else {
            custom.style.display = 'none';
            custom.required = false;
            custom.value = '';
            custom.removeAttribute('name');
            sel.name = 'ESource';
        }
    }

    function toggleConsumable() {
        var isConsumable = document.getElementById('consumableYes').checked;
        document.getElementById('equipmentSection').style.display = isConsumable ? 'none' : '';
        document.getElementById('consumableSection').style.display = isConsumable ? '' : 'none';
    }

    document.addEventListener('DOMContentLoaded', function () {
        var qtyInput = document.getElementById('eqQtyInput');
        qtyInput.addEventListener('change', function () {
            var qty = parseInt(this.value) || 0;
            var container = document.getElementById('eidContainer');
            if (qty <= 0) { container.innerHTML = ''; return; }

            var html = '<label class="form-label fw-semibold small">請輸入每台設備的編號</label><div class="row g-2">';
            for (var i = 0; i < qty; i++) {
                html += '<div class="col-md-3 col-6"><div class="input-group input-group-sm">'
                    + '<span class="input-group-text" style="font-size:.75rem;">#' + (i + 1) + '</span>'
                    + '<input type="text" name="EId[]" class="form-control form-control-sm" placeholder="編號" autocomplete="off" />'
                    + '</div></div>';
            }
            html += '</div>';
            container.innerHTML = html;
        });
    });
</script>
}
