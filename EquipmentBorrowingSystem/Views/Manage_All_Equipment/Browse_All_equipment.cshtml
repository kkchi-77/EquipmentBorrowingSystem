@model EquipmentBorrowingSystem.ViewModel.Browse_equipment1ViewModel
@{
    ViewData["Title"] = "管理所有設備";
    Layout = "~/Views/Shared/_Layout_Manager.cshtml";

    var totalCount = Model.Equipment.Count();
    var availableCount = Model.Equipment.Count(e => e.ERemaining_Quantity != "0");
    var borrowingCount = Model.Equipment.Sum(e => int.TryParse(e.EBorrowing_Quantity, out var v) ? v : 0);
    var missingCount = Model.Equipment.Sum(e => int.TryParse(e.EMissing_quantity, out var v) ? v : 0);

    bool isSearchResult = !string.IsNullOrEmpty(Model.keyword) || (Model.select != null && Model.select != "全部設備");
}

<div class="page-header">
    <h4><i class="bi bi-tools me-2" style="color:#5b9bd5;"></i>管理所有設備</h4>
    <p class="page-subtitle">查看、新增、修改及刪除所有設備資料</p>
</div>

@* ===== Search Box ===== *@
<div class="search-box mb-4">
    <div class="row g-3 align-items-end">
        <div class="col-12 col-md-auto">
            <form action="@Url.Action("Browse_All_equipment", "Manage_All_Equipment")" method="post">
                <label class="form-label fw-semibold small mb-1">關鍵字搜尋</label>
                <div class="input-group input-group-sm">
                    <input type="text" name="keyword" placeholder="設備名稱、型號..." autocomplete="off"
                           class="form-control" style="min-width:180px;" value="@Model.keyword" />
                    <button type="submit" class="btn btn-accent">
                        <i class="bi bi-search"></i> 查詢
                    </button>
                </div>
            </form>
        </div>
        <div class="col-12 col-md-auto">
            <form action="@Url.Action("Browse_All_equipment", "Manage_All_Equipment")" method="post">
                <label class="form-label fw-semibold small mb-1">設備分類</label>
                <div class="input-group input-group-sm">
                    @{
                        var categories = new[] { "頭盔", "平板", "筆電", "麥克風", "傳輸線", "轉接線", "其他" };
                    }
                    <select name="select" class="form-select" style="min-width:130px;">
                        <option value="查詢全部">全部</option>
                        @foreach (var cat in categories)
                        {
                            if (Model.select == cat)
                            {
                                <option value="@cat" selected>@cat</option>
                            }
                            else
                            {
                                <option value="@cat">@cat</option>
                            }
                        }
                    </select>
                    <button type="submit" class="btn btn-accent">
                        <i class="bi bi-funnel"></i> 篩選
                    </button>
                </div>
            </form>
        </div>
        <div class="col-12 col-md-auto">
            <label class="form-label fw-semibold small mb-1 d-block">&nbsp;</label>
            <a href="@Url.Action("Browse_All_equipment", "Manage_All_Equipment")" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-arrow-clockwise me-1"></i>全部顯示
            </a>
        </div>
        <div class="col-12 col-md-auto ms-md-auto">
            <label class="form-label fw-semibold small mb-1 d-block">&nbsp;</label>
            <a href="@Url.Action("Create", "Manage_All_Equipment")" class="btn btn-sm btn-success">
                <i class="bi bi-plus-lg me-1"></i>新增設備
            </a>
        </div>
    </div>
</div>

@* ===== Search Result Info ===== *@
@if (isSearchResult)
{
    <div class="alert alert-light border d-flex align-items-center gap-2 py-2 mb-3">
        <i class="bi bi-info-circle text-primary"></i>
        <small>
            @if (!string.IsNullOrEmpty(Model.keyword))
            {
                <span>關鍵字「@Model.keyword」，共 <strong>@totalCount</strong> 筆</span>
            }
            else
            {
                <span>分類「@Model.select」，共 <strong>@totalCount</strong> 筆</span>
            }
        </small>
    </div>
}

@* ===== Stat Cards ===== *@
@if (!isSearchResult)
{
    <div class="row g-3 mb-4">
        <div class="col-6 col-xl-3">
            <div class="stat-card stat-primary">
                <div class="stat-icon"><i class="bi bi-box-seam"></i></div>
                <div>
                    <div class="stat-number">@totalCount</div>
                    <div class="stat-label">設備種類總數</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="stat-card" style="border-left:4px solid #27ae60;">
                <div class="stat-icon" style="color:#27ae60;"><i class="bi bi-check-circle"></i></div>
                <div>
                    <div class="stat-number">@availableCount</div>
                    <div class="stat-label">可借用設備</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="stat-card" style="border-left:4px solid #e67e22;">
                <div class="stat-icon" style="color:#e67e22;"><i class="bi bi-arrow-left-right"></i></div>
                <div>
                    <div class="stat-number">@borrowingCount</div>
                    <div class="stat-label">借用中數量</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="stat-card" style="border-left:4px solid #e74c3c;">
                <div class="stat-icon" style="color:#e74c3c;"><i class="bi bi-exclamation-triangle"></i></div>
                <div>
                    <div class="stat-number">@missingCount</div>
                    <div class="stat-label">遺失數量</div>
                </div>
            </div>
        </div>
    </div>
}

@* ===== Main Table ===== *@
<div class="content-card">
    <div class="content-card-header">
        <h5><i class="bi bi-tools"></i> 設備列表</h5>
        <span class="badge" style="background:rgba(91,155,213,0.15);color:#2d6fa3;font-weight:600;">
            共 @totalCount 筆
        </span>
    </div>
    <div class="table-responsive">
        <table class="table table-hover table-custom mb-0">
            <thead>
                <tr>
                    <th style="width:4%">#</th>
                    <th style="width:22%">設備名稱</th>
                    <th style="width:14%">型號</th>
                    <th style="width:7%">來源</th>
                    <th style="width:6%">類型</th>
                    <th style="width:7%">總數量</th>
                    <th style="width:8%">借用中</th>
                    <th style="width:7%">剩餘</th>
                    <th style="width:7%">遺失</th>
                    <th style="width:18%">操作</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Equipment.Any())
                {
                    <tr>
                        <td colspan="10" class="text-center py-5 text-muted">
                            <i class="bi bi-inbox fs-3 d-block mb-2"></i>找不到符合的設備
                        </td>
                    </tr>
                }
                @{ var rowNum = 0; }
                @foreach (var item in Model.Equipment)
                {
                    rowNum++;
                    var borrowQty = int.TryParse(item.EBorrowing_Quantity, out var bq) ? bq : 0;
                    var missingQty = int.TryParse(item.EMissing_quantity, out var mq) ? mq : 0;
                    var remainQty = int.TryParse(item.ERemaining_Quantity, out var rq) ? rq : 0;
                    <tr>
                        <td class="text-center text-muted">@rowNum</td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                @if (!string.IsNullOrWhiteSpace(item.EImage) && item.EImage.Trim() != " " && item.EImage.Trim() != "")
                                {
                                    <img src="~/Image/@item.EImage" alt="" class="rounded"
                                         style="width:32px; height:32px; object-fit:cover; cursor:pointer; border:1px solid #e9ecef;"
                                         onclick="showEqImage('@Html.Raw(item.EImage.Replace("'", "\\'"))', '@Html.Raw(item.EName.Replace("'", "\\'")) @Html.Raw(item.Emodel.Replace("'", "\\'"))')"
                                         title="點擊放大" />
                                }
                                else
                                {
                                    <span class="d-inline-flex align-items-center justify-content-center rounded"
                                          style="width:32px; height:32px; background:#f0f0f0; color:#ccc; font-size:.8rem; border:1px solid #e9ecef;"
                                          title="無圖片">
                                        <i class="bi bi-image"></i>
                                    </span>
                                }
                                <span class="fw-semibold">@item.EName</span>
                            </div>
                        </td>
                        <td>@item.Emodel</td>
                        <td>
                            <span class="badge @(item.ESource == "自購" ? "bg-info text-dark" : "bg-secondary")" style="font-size:.72rem;">
                                @item.ESource
                            </span>
                        </td>
                        <td>
                            @if (item.Is_Consumable == "True")
                            {
                                <span class="badge bg-warning text-dark" style="font-size:.72rem;">消耗品</span>
                            }
                            else
                            {
                                <span class="badge bg-light text-dark border" style="font-size:.72rem;">設備</span>
                            }
                        </td>
                        <td class="text-center">
                            <strong>@item.EQuantity</strong> <small class="text-muted">@item.EQuantity_Unit</small>
                        </td>
                        <td class="text-center">
                            @if (borrowQty > 0)
                            {
                                <span class="text-warning fw-semibold">@item.EBorrowing_Quantity</span>
                            }
                            else
                            {
                                <span class="text-muted">0</span>
                            }
                        </td>
                        <td class="text-center">
                            @if (remainQty > 0)
                            {
                                <span class="text-success fw-semibold">@item.ERemaining_Quantity</span>
                            }
                            else
                            {
                                <span class="text-danger fw-semibold">0</span>
                            }
                        </td>
                        <td class="text-center">
                            @if (missingQty > 0)
                            {
                                <span class="text-danger fw-semibold">@item.EMissing_quantity</span>
                            }
                            else
                            {
                                <span class="text-muted">0</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex flex-wrap gap-1">
                                @if (item.Is_Consumable != "True")
                                {
                                    <button type="button" class="btn btn-sm btn-outline-primary" style="font-size:.75rem;"
                                            onclick="showEIdModal('@item.EName', '@item.Emodel', '@item.ESource')">
                                        <i class="bi bi-list-ol me-1"></i>編號
                                    </button>
                                }
                                <form action="@Url.Action("Update", "Manage_All_Equipment")" method="post" class="d-inline">
                                    <input type="hidden" name="EName" value="@item.EName" />
                                    <input type="hidden" name="Emodel" value="@item.Emodel" />
                                    <input type="hidden" name="ESource" value="@item.ESource" />
                                    <input type="hidden" name="Is_Consumable" value="@item.Is_Consumable" />
                                    <button type="submit" class="btn btn-sm btn-outline-secondary" style="font-size:.75rem;">
                                        <i class="bi bi-pencil me-1"></i>修改
                                    </button>
                                </form>
                                <form action="@Url.Action("Delete", "Manage_All_Equipment")" method="post" class="d-inline">
                                    <input type="hidden" name="EName" value="@item.EName" />
                                    <input type="hidden" name="Emodel" value="@item.Emodel" />
                                    <input type="hidden" name="ESource" value="@item.ESource" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger" style="font-size:.75rem;"
                                            onclick="return confirm('確定要刪除「@item.EName (@item.Emodel)」及所有編號嗎？此操作無法復原。')">
                                        <i class="bi bi-trash me-1"></i>刪除
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@* ===== 設備圖片預覽 Modal ===== *@
<div class="modal fade" id="eqImageModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:480px;">
        <div class="modal-content" style="border-radius:12px; overflow:hidden;">
            <div class="modal-header py-2" style="background:#f0f4f8; border-bottom:1px solid #e9ecef;">
                <h6 class="modal-title fw-bold" style="font-size:.85rem;" id="eqImageTitle">設備圖片</h6>
                <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center p-3">
                <img id="eqImagePreview" src="" alt="設備圖片" style="max-width:100%; max-height:400px; border-radius:8px; object-fit:contain;" />
                <div id="eqImageNone" class="py-4 text-muted" style="display:none;">
                    <i class="bi bi-image fs-1 d-block mb-2" style="opacity:.3;"></i>
                    <small>此設備尚未上傳圖片</small>
                </div>
            </div>
        </div>
    </div>
</div>

@* ===== EId Modal ===== *@
<div class="modal fade" id="eidModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:12px; overflow:hidden;">
            <div class="modal-header py-2" style="background:#f0f4f8; border-bottom:1px solid #e9ecef;">
                <h6 class="modal-title fw-bold" id="eidModalTitle">設備編號</h6>
                <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-3" id="eidModalBody">
                <div class="text-center py-4 text-muted">
                    <div class="spinner-border spinner-border-sm me-1"></div> 載入中...
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function showEIdModal(eName, emodel, eSource) {
        var modal = new bootstrap.Modal(document.getElementById('eidModal'));
        document.getElementById('eidModalTitle').textContent = eName + ' | ' + emodel;
        document.getElementById('eidModalBody').innerHTML = '<div class="text-center py-4 text-muted"><div class="spinner-border spinner-border-sm me-1"></div> 載入中...</div>';
        modal.show();

        fetch('@Url.Action("GetEquipmentEIds", "Manage_All_Equipment")?eName=' + encodeURIComponent(eName)
            + '&emodel=' + encodeURIComponent(emodel)
            + '&eSource=' + encodeURIComponent(eSource))
            .then(function (r) { return r.json(); })
            .then(function (data) {
                if (!data || data.length === 0) {
                    document.getElementById('eidModalBody').innerHTML = '<div class="text-center py-3 text-muted"><i class="bi bi-inbox d-block mb-1" style="font-size:1.3rem;"></i>無編號資料</div>';
                    return;
                }
                var html = '<div class="table-responsive"><table class="table table-sm table-hover mb-0" style="font-size:.82rem;">';
                html += '<thead style="background:#f0f4f8;"><tr><th class="text-center" style="width:25%">編號</th><th class="text-center" style="width:25%">狀態</th><th style="width:50%">存放位置</th></tr></thead><tbody>';
                data.forEach(function (item) {
                    var badge = '';
                    if (item.isBorrow === 'True') badge = '<span class="badge bg-warning text-dark">借用中</span>';
                    else if (item.isBorrow === 'Missing') badge = '<span class="badge bg-danger">遺失</span>';
                    else badge = '<span class="badge bg-success">可借用</span>';
                    html += '<tr><td class="text-center fw-semibold">' + escHtml(item.eId) + '</td><td class="text-center">' + badge + '</td><td><small>' + escHtml(item.eCurrent_Location) + '</small></td></tr>';
                });
                html += '</tbody></table></div>';
                document.getElementById('eidModalBody').innerHTML = html;
            })
            .catch(function () {
                document.getElementById('eidModalBody').innerHTML = '<div class="text-center text-danger py-3">載入失敗</div>';
            });
    }

    function showEqImage(imageName, title) {
        var imgEl = document.getElementById('eqImagePreview');
        var noneEl = document.getElementById('eqImageNone');
        document.getElementById('eqImageTitle').textContent = title || '設備圖片';
        if (imageName && imageName.trim() && imageName.trim() !== ' ') {
            imgEl.src = '/Image/' + encodeURIComponent(imageName.trim());
            imgEl.style.display = 'block';
            noneEl.style.display = 'none';
        } else {
            imgEl.style.display = 'none';
            noneEl.style.display = 'block';
        }
        new bootstrap.Modal(document.getElementById('eqImageModal')).show();
    }

    function escHtml(str) {
        if (!str) return '';
        var d = document.createElement('div');
        d.appendChild(document.createTextNode(str));
        return d.innerHTML;
    }
</script>
}
