@model IEnumerable<EquipmentBorrowingSystem.Models.Equipment_Details>
@{
    ViewData["Title"] = "設備編號詳細資訊";
    Layout = "~/Views/Shared/_Layout_Manager.cshtml";
    var first = Model.FirstOrDefault();
}

<div class="page-header">
    <h4><i class="bi bi-list-ol me-2" style="color:#5b9bd5;"></i>設備編號詳細資訊</h4>
    @if (first != null)
    {
        <p class="page-subtitle">@first.EName — @first.Emodel（@first.ESource）</p>
    }
</div>

<div class="content-card">
    <div class="content-card-header">
        <h5><i class="bi bi-list-ol"></i> 編號列表</h5>
        <span class="badge" style="background:rgba(91,155,213,0.15);color:#2d6fa3;font-weight:600;">
            共 @Model.Count() 筆
        </span>
    </div>
    <div class="table-responsive">
        <table class="table table-hover table-custom mb-0">
            <thead>
                <tr>
                    <th class="text-center" style="width:10%">#</th>
                    <th class="text-center" style="width:20%">設備編號</th>
                    <th class="text-center" style="width:20%">借用狀態</th>
                    <th style="width:50%">設備存放位置</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center py-5 text-muted">
                            <i class="bi bi-inbox fs-3 d-block mb-2"></i>無編號資料
                        </td>
                    </tr>
                }
                @{ var idx = 0; }
                @foreach (var item in Model)
                {
                    idx++;
                    <tr>
                        <td class="text-center text-muted">@idx</td>
                        <td class="text-center fw-semibold">@item.EId</td>
                        <td class="text-center">
                            @if (item.IsBorrow == "True")
                            {
                                <span class="status-badge badge-applying" style="background:rgba(230,126,34,0.12);color:#e67e22;font-size:.75rem;padding:3px 10px;border-radius:20px;">
                                    <i class="bi bi-arrow-left-right"></i> 借用中
                                </span>
                            }
                            else if (item.IsBorrow == "Missing")
                            {
                                <span class="status-badge" style="background:rgba(231,76,60,0.12);color:#e74c3c;font-size:.75rem;padding:3px 10px;border-radius:20px;">
                                    <i class="bi bi-exclamation-triangle"></i> 遺失
                                </span>
                            }
                            else
                            {
                                <span class="status-badge badge-approved" style="background:rgba(39,174,96,0.12);color:#1a7a33;font-size:.75rem;padding:3px 10px;border-radius:20px;">
                                    <i class="bi bi-check-circle-fill"></i> 可借用
                                </span>
                            }
                        </td>
                        <td><small>@item.ECurrent_Location</small></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="mt-3">
    <a href="@Url.Action("Browse_All_equipment", "Manage_All_Equipment")" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>返回管理介面
    </a>
</div>
