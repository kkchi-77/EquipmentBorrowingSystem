@model EquipmentBorrowingSystem.Models.Application
@{
    ViewBag.Title = "接受借用申請";
    Layout = "~/Views/Shared/_Layout_Manager.cshtml";
}

<div class="page-header">
    <h4><i class="bi bi-check-circle me-2" style="color:#27ae60;"></i>確認接受此筆申請</h4>
    <p class="page-subtitle">請確認申請資訊並填寫移交資料</p>
</div>

<div class="content-card">
    <div class="content-card-header">
        <h5><i class="bi bi-info-circle"></i> 申請資訊</h5>
    </div>
    <div class="p-3">
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label fw-semibold small text-muted">借用人</label>
                <div class="fw-semibold">@Model.Name</div>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold small text-muted">聯絡電話</label>
                <div>@Model.Mobile</div>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold small text-muted">Email</label>
                <div>@Model.fEmail</div>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold small text-muted">用途說明</label>
                <div>@Model.Illustrate</div>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold small text-muted">借用日期</label>
                <div style="color:#1a7a33;"><i class="bi bi-box-arrow-up-right me-1"></i>@Model.Borrow_Time.ToString("yyyy/MM/dd HH:mm")</div>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold small text-muted">歸還日期</label>
                <div style="color:#c0392b;"><i class="bi bi-box-arrow-in-down-left me-1"></i>@(Model.Return_Time.Year >= 9999 ? "無期限" : Model.Return_Time.ToString("yyyy/MM/dd HH:mm"))</div>
            </div>
        </div>
    </div>
</div>

<div class="content-card mt-3">
    <div class="content-card-header">
        <h5><i class="bi bi-pencil-square"></i> 移交資訊</h5>
    </div>
    <div class="p-3">
        <form action="@Url.Action("ApplicationCompleted", "ApplicationCompleted")" method="post">
            <input type="hidden" name="fOrderGuid" value="@Model.fOrderGuid" />
            <div class="row g-3">
                <div class="col-md-6">
                    <label for="Credentials_Mortgage" class="form-label fw-semibold small">申請人是否需抵押證件</label>
                    <select name="Credentials_Mortgage" id="Credentials_Mortgage" class="form-select form-select-sm">
                        <option value="身分免押">身分免押</option>
                        <option value="學生證">學生證</option>
                        <option value="駕照">駕照</option>
                        <option value="身分證">身分證</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label for="Equipment_Handover_Person" class="form-label fw-semibold small">接受人姓名（設備移交人）</label>
                    <input type="text" id="Equipment_Handover_Person" name="Equipment_Handover_Person"
                           class="form-control form-control-sm" required placeholder="請輸入移交人姓名" />
                </div>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-success btn-sm px-4">
                    <i class="bi bi-check-circle me-1"></i>確認接受
                </button>
                <a href="@Url.Action("PendingApplications", "ApplicationCompleted")" class="btn btn-outline-secondary btn-sm px-4">
                    <i class="bi bi-arrow-left me-1"></i>返回申請列表
                </a>
            </div>
        </form>
    </div>
</div>
