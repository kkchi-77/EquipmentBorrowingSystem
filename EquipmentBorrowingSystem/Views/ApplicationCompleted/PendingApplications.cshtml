@model IEnumerable<EquipmentBorrowingSystem.Models.Application>
@{
    ViewBag.Title = "審核借用申請";
    Layout = "~/Views/Shared/_Layout_Manager.cshtml";
    DateTime targetDate = new DateTime(2000, 10, 10);
    int itemcount = 0;
    int pendingCount = Model.Count(m => m.Status == "Applying");
}

<div class="page-header">
    <h4><i class="bi bi-clipboard-check me-2" style="color:#5b9bd5;"></i>審核借用申請</h4>
    <p class="page-subtitle">審核使用者提交的設備借用申請</p>
</div>

@if (pendingCount > 0)
{
    <div class="row g-3 mb-4">
        <div class="col-6 col-xl-3">
            <div class="stat-card stat-warning">
                <div class="stat-icon"><i class="bi bi-hourglass-split"></i></div>
                <div>
                    <div class="stat-number">@pendingCount</div>
                    <div class="stat-label">待審核</div>
                </div>
            </div>
        </div>
    </div>
}

<div class="content-card">
    <div class="content-card-header">
        <h5><i class="bi bi-clipboard2-check"></i> 待審核申請列表</h5>
        <span class="badge" style="background:rgba(91,155,213,0.15);color:#2d6fa3;font-weight:600;">
            共 @pendingCount 筆
        </span>
    </div>
    <div class="table-responsive">
        <table class="table table-hover table-custom mb-0">
            <thead>
                <tr>
                    <th style="width:4%">#</th>
                    <th style="width:20%">申請 / 借用 / 歸還 日期</th>
                    <th style="width:9%">借用人</th>
                    <th style="width:18%">聯絡方式</th>
                    <th style="width:18%">用途說明</th>
                    <th style="width:10%">審核狀態</th>
                    <th style="width:21%">操作</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center py-5 text-muted">
                            <i class="bi bi-check-circle fs-3 d-block mb-2"></i>目前沒有待審核的申請
                        </td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    itemcount++;
                    <tr>
                        <td class="text-center text-muted">@itemcount</td>
                        <td>
                            @if (item.Date_Of_Application == targetDate)
                            {
                                <span class="badge bg-secondary mb-1">管理者申請</span><br />
                            }
                            else
                            {
                                <small class="text-muted">(申) @item.Date_Of_Application.ToString("yyyy/MM/dd")</small><br />
                            }
                            <small style="color:#1a7a33;"><i class="bi bi-box-arrow-up-right"></i> @item.Borrow_Time.ToString("yyyy/MM/dd HH:mm")</small><br />
                            <small style="color:#c0392b;"><i class="bi bi-box-arrow-in-down-left"></i> @(item.Return_Time.Year >= 9999 ? "無期限" : item.Return_Time.ToString("yyyy/MM/dd HH:mm"))</small>
                        </td>
                        <td class="fw-semibold">@item.Name</td>
                        <td>
                            <small><i class="bi bi-telephone me-1"></i>@item.Mobile</small><br />
                            <small class="text-muted"><i class="bi bi-envelope me-1"></i>@item.fEmail</small>
                        </td>
                        <td><small>@item.Illustrate</small></td>
                        <td class="text-center">
                            <span class="status-badge badge-applying">
                                <i class="bi bi-hourglass-split"></i> 審核中
                            </span>
                        </td>
                        <td>
                            <div class="d-flex flex-column gap-1">
                                <button type="button" class="btn btn-sm btn-outline-primary w-100" style="font-size:.78rem;"
                                        onclick="showDetailModal('@item.fOrderGuid', '@Url.Action("GetApplicationDetails", "ApplicationCompleted")')">
                                    <i class="bi bi-list-ul me-1"></i>詳細資訊
                                </button>
                                <a href="@Url.Action("AcceptApplication", "ApplicationCompleted", new { fOrderGuid = item.fOrderGuid })"
                                   class="btn btn-sm btn-success w-100" style="font-size:.78rem;">
                                    <i class="bi bi-check-circle me-1"></i>接受申請
                                </a>
                                <form action="@Url.Action("RejectApplication", "ApplicationCompleted")" method="post">
                                    <input type="hidden" name="fOrderGuid" value="@item.fOrderGuid" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger w-100"
                                            onclick="return confirm('確定要拒絕（取消）此筆申請嗎？')" style="font-size:.78rem;">
                                        <i class="bi bi-x-circle me-1"></i>拒絕申請
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@await Html.PartialAsync("_DetailModal")
